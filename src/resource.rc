#include <windows.h>

// 如需自定义图标，取消下一行注释，并将icon.ico放在src目录
// IDI_ICON1 ICON "icon.ico"

IDD_MAIN DIALOGEX 0, 0, 380, 320
STYLE DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "本地IP地址切换器"
FONT 9, "微软雅黑"
BEGIN
    LTEXT "网络适配器:", IDC_STATIC, 15, 15, 70, 12
    COMBOBOX IDC_ADAPTER_COMBO, 90, 12, 270, 120, CBS_DROPDOWNLIST | WS_TABSTOP

    GROUPBOX "IP配置", IDC_STATIC, 15, 40, 350, 130
    LTEXT "IP地址:", IDC_STATIC, 30, 62, 50, 12
    EDITTEXT IDC_IP_EDIT, 90, 60, 130, 18, ES_AUTOHSCROLL
    LTEXT "子网掩码:", IDC_STATIC, 30, 90, 50, 12
    EDITTEXT IDC_MASK_EDIT, 90, 88, 130, 18, ES_AUTOHSCROLL
    LTEXT "默认网关:", IDC_STATIC, 30, 118, 50, 12
    EDITTEXT IDC_GATEWAY_EDIT, 90, 116, 130, 18, ES_AUTOHSCROLL

    LTEXT "首选DNS:", IDC_STATIC, 235, 62, 50, 12
    EDITTEXT IDC_DNS1_EDIT, 290, 60, 65, 18, ES_AUTOHSCROLL
    LTEXT "备用DNS:", IDC_STATIC, 235, 90, 50, 12
    EDITTEXT IDC_DNS2_EDIT, 290, 88, 65, 18, ES_AUTOHSCROLL

    AUTOCHECKBOX "自动获取IP(DHCP)", IDC_DHCP_CHECK, 235, 118, 120, 12

    GROUPBOX "配置管理", IDC_STATIC, 15, 185, 350, 80
    LTEXT "配置名称:", IDC_STATIC, 30, 210, 50, 12
    EDITTEXT IDC_PROFILE_NAME, 90, 208, 130, 18, ES_AUTOHSCROLL
    COMBOBOX IDC_PROFILE_COMBO, 90, 235, 130, 100, CBS_DROPDOWNLIST | WS_TABSTOP

    PUSHBUTTON "保存配置", IDC_SAVE_BTN, 240, 207, 55, 22
    PUSHBUTTON "加载配置", IDC_LOAD_BTN, 300, 207, 55, 22
    PUSHBUTTON "删除配置", IDC_DELETE_BTN, 240, 233, 55, 22
    PUSHBUTTON "应用配置", IDC_APPLY_BTN, 300, 233, 55, 22

    DEFPUSHBUTTON "退出", IDOK, 305, 285, 60, 22
END
